APP_NAME=AuditPilot Local
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./backend/data/auditpilot.db
REDIS_URL=redis://127.0.0.1:6379/0
SQL_ECHO=false
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
REPORT_HISTORY_LIMIT=200
LLM_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true
LLM_TIMEOUT_SECONDS=60
LLM_MAX_OUTPUT_TOKENS=4096
LLM_MAX_REVIEW_FILES=6
LLM_MAX_FILE_CHARS=6000
LLM_MAX_FINDINGS=8
LLM_CONTEXT_INDEX_MAX_FILES=160
LLM_CONTEXT_REFERENCE_LIMIT=3
