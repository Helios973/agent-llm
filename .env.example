APP_NAME=AuditPilot Local
API_V1_PREFIX=/api/v1
PYTHON_EXECUTABLE=
BACKEND_SCHEME=http
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=
FRONTEND_SCHEME=http
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=3000
FRONTEND_PUBLIC_URL=
FRONTEND_API_BASE_URL=
AUTH_SECRET_KEY=change-me-local-auth-secret
AUTH_TOKEN_TTL_SECONDS=604800
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=Admin123456!
ADMIN_BOOTSTRAP_RESET_PASSWORD=false
DATABASE_URL=sqlite:///./backend/data/auditpilot.db
REDIS_URL=redis://127.0.0.1:6379/0
SQL_ECHO=false
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
REPORT_HISTORY_LIMIT=200
LLM_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING_ENABLED=true
LLM_TIMEOUT_SECONDS=60
LLM_MAX_OUTPUT_TOKENS=4096
LLM_MAX_REVIEW_FILES=6
LLM_MAX_FILE_CHARS=6000
LLM_MAX_FINDINGS=8
LLM_CONTEXT_INDEX_MAX_FILES=160
LLM_CONTEXT_REFERENCE_LIMIT=3
JAVA_AUDIT_SKILLS_ENABLED=true
JAVA_AUDIT_SKILLS_ROOT=
JAVA_LLM_FULL_FILE_CONTEXT=true
JAVA_LLM_MAX_REVIEW_FILES=4
JAVA_HEURISTIC_REQUIRES_CORROBORATION=true
JAVA_CORROBORATION_LINE_RADIUS=8
